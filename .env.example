# 공공데이터포털 서비스 키
PUBLIC_DATA_SERVICE_KEY=여기에_공공데이터포털_서비스키_입력

# Supabase Pooler 연결 문자열 (Transaction mode 권장)
# Supabase 대시보드 > Settings > Database > Connection pooling > Transaction mode
# 형식: postgresql://postgres.프로젝트ID:비밀번호@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.프로젝트ID:비밀번호@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
